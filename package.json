{
  "name": "comeoffline",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --no-daemon",
    "dev:app": "npm -w @comeoffline/app run dev",
    "dev:api": "npm -w @comeoffline/api run dev",
    "dev:admin": "npm -w @comeoffline/admin run dev",
    "dev:landing": "npm -w @comeoffline/landing run dev",
    "build": "turbo build --no-daemon",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "esbuild": "^0.27.3",
    "lodash.isstring": "^4.0.1"
  }
}
