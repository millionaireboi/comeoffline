rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    // Helper: check if user owns this document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Users — read own profile, admins read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin(); // created by backend on auth
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Events — all authenticated users can read, admins can write
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      // RSVPs — users can read own, create own, admins manage
      match /rsvps/{rsvpId} {
        allow read: if isAdmin() || (isAuth() && resource.data.user_id == request.auth.uid);
        allow create: if isAuth();
        allow update, delete: if isAdmin();
      }

      // Polaroids — all authenticated can read, admins write
      match /polaroids/{polaroidId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }

      // Quotes — all authenticated can read, admins write
      match /quotes/{quoteId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }
    }

    // Connections — users can read own, create own, admins manage
    match /connections/{connectionId} {
      allow read: if isAdmin() || (isAuth() && (resource.data.from_user_id == request.auth.uid || resource.data.to_user_id == request.auth.uid));
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Applications — anyone can create (prove yourself), admins manage
    match /applications/{applicationId} {
      allow create: if true; // public submission
      allow read, update, delete: if isAdmin();
    }

    // Vouch codes — users can read own, admins manage
    match /vouch_codes/{codeId} {
      allow read: if isAdmin() || (isAuth() && resource.data.owner_id == request.auth.uid);
      allow write: if isAdmin();
    }

    // Admin users — only admins
    match /admin_users/{adminId} {
      allow read, write: if isAdmin();
    }

    // Settings — only admins
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Server-only collections (Admin SDK bypasses rules) ──
    // Explicit deny for clarity — managed exclusively via the API

    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    match /tickets/{ticketId} {
      allow read, write: if false;
    }

    match /community_polls/{pollId} {
      allow read, write: if false;
    }

    match /contact_submissions/{submissionId} {
      allow read, write: if false;
    }

    match /brand_inquiries/{inquiryId} {
      allow read, write: if false;
    }

    match /chat_sessions/{sessionId} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
