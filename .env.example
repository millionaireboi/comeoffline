# ─── Firebase (frontend — all Next.js apps) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── API URL (frontend — all Next.js apps) ───
# Local: http://localhost:8080
# Production: https://api.comeoffline.com (or your Cloud Run URL)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── App URL (for landing page redirect) ───
# Local: http://localhost:3001
# Production: https://app.comeoffline.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Backend (apps/api) ───
PORT=8080

# Firebase Admin — paste the full JSON service account key as a single line
FIREBASE_SERVICE_ACCOUNT_KEY=

# Google AI (Gemini) — for chatbot
GOOGLE_AI_API_KEY=

# Firebase Storage bucket name (e.g. comeoffline.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Razorpay (Payment Links)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
APP_URL=http://localhost:3001

# Razorpay Webhook Secret (from Razorpay Dashboard → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=

# QR Code Signing Secret — used to HMAC-sign ticket QR codes to prevent forgery
# Generate with: openssl rand -hex 32
QR_SIGNING_SECRET=

# WhatsApp Cloud API (Meta)
# Phone Number ID: from Meta for Developers → WhatsApp → API Setup (long numeric)
# Access Token: System User permanent token (Business Settings → Users → System users)
# Verify Token: any random string — must match the value entered when configuring the
#   webhook URL in Meta Business Manager → WhatsApp → Configuration → Webhook
# App Secret: App Dashboard → Settings → Basic → App Secret. Used to verify Meta's
#   X-Hub-Signature-256 on inbound webhook calls. Optional but recommended.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# WABA ID: WhatsApp Business Account ID. Find in business.facebook.com URLs (waba_id=...)
# or WhatsApp Manager → Account Tools → Settings. Required for template management endpoints.
WHATSAPP_WABA_ID=

# CORS — comma-separated allowed origins
# Local: http://localhost:3000,http://localhost:3001,http://localhost:3002
# Production: https://comeoffline.com,https://app.comeoffline.com,https://admin.comeoffline.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── GCP (CI/CD — set as GitHub Secrets, not in .env) ───
# GCP_PROJECT_ID=
# GCP_WORKLOAD_IDENTITY_PROVIDER=
# GCP_SERVICE_ACCOUNT=
